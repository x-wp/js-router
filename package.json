{
  "name": "@x-wp/router",
  "version": "0.0.0",
  "license": "GPL-3.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "contributors": [
    {
      "name": "Sibin Grasic",
      "email": "sibin.grasic@oblak.studio",
      "url": "https://oblak.studio"
    },
    {
      "name": "Dessolator",
      "email": "dessolator@oblak.studio",
      "url": "https://zabole.me"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/x-wp/js-router.git"
  },
  "bugs": "https://github.com/x-wp/js-router/issues",
  "keywords": [
    "wp-router",
    "WP router",
    "body class router"
  ],
  "scripts": {
    "build": "rimraf dist .rollup && npm run build:types && npm run build:js",
    "build:js": "tsc --project tsconfig.rollup.json && rollup --config && rimraf .rollup",
    "build:types": "tsc --project tsconfig.types.json",
    "watch": "tsc --project tsconfig.rollup.json --watch",
    "build:production": "npm run build",
    "test": "jest",
    "test:package": "node scripts/check-package.js && node scripts/check-exports.js",
    "lint": "eslint lib/*.ts",
    "release:test": "node ./node_modules/semantic-release/bin/semantic-release.js --dry-run",
    "release": "node ./node_modules/semantic-release/bin/semantic-release.js"
  },
  "engines": {
    "node": ">= 14.0.0"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^13.3.0",
    "@semantic-release/changelog": "^5.0.1",
    "@semantic-release/exec": "^5.0.0",
    "@semantic-release/git": "^9.0.0",
    "@semantic-release/github": "^7.2.3",
    "@semantic-release/npm": "^7.1.3",
    "@types/jest": "^27.5.2",
    "@typescript-eslint/eslint-plugin": "^4.31.2",
    "@typescript-eslint/parser": "^4.31.2",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "^27.5.1",
    "prettier": "^2.4.1",
    "rimraf": "^3.0.2",
    "rollup": "^2.80.0",
    "semantic-release": "^17.4.3",
    "ts-jest": "^27.1.5",
    "typescript": "^4.4.3"
  },
  "dependencies": {
    "camelcase": "^6.2.0"
  }
}
