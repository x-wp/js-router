{
  "name": "@x-wp/router",
  "version": "v1.0.0",
  "license": "GPL-3.0",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "contributors": [
    {
      "name": "Sibin Grasic",
      "email": "sibin.grasic@oblak.studio",
      "url": "https://oblak.studio"
    },
    {
      "name": "Dessolator",
      "email": "dessolator@oblak.studio",
      "url": "https://zabole.me"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/x-wp/js-router.git"
  },
  "bugs": "https://github.com/x-wp/js-router/issues",
  "keywords": [
    "wp-router",
    "WP router",
    "body class router"
  ],
  "scripts": {
    "build": "rimraf dist && rollup -c",
    "watch": "rimraf dist && rollup -c --watch",
    "build:production": "rimraf dist && rollup -c --environment BUILD:production",
    "lint": "eslint lib/*.ts",
    "test": "jest"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.umd.js",
  "jsdelivr": "./dist/index.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./umd": {
      "types": "./dist/index.umd.d.ts",
      "default": "./dist/index.umd.js"
    }
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/babel__traverse": "^7.18.3",
    "@types/jest": "^27.5.2",
    "@types/node": "^14.18.63",
    "@typescript-eslint/eslint-plugin": "^4.31.2",
    "@typescript-eslint/parser": "^4.31.2",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "^27.5.1",
    "prettier": "^2.4.1",
    "rimraf": "^3.0.2",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "ts-jest": "^27.1.5",
    "tslib": "^2.8.1",
    "typescript": "~4.9.5"
  }
}
